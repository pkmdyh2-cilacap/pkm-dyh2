{
  "name": "pralokmin-supabase-backend",
  "version": "1.0.0",
  "description": "Backend Pralokmin dengan Supabase",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:mutation": "stryker run",
    "test:e2e": "playwright test --config __tests__/e2e/playwright.config.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jszip": "^3.10.1",
    "multer": "^2.2.0"
  },
  "jest": {
    "setupFiles": [
      "./__tests__/setup.js"
    ],
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/__tests__/"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/__tests__/setup\\.js$",
      "/__tests__/helpers/",
      "/__tests__/e2e/"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 100,
        "functions": 96,
        "lines": 100,
        "statements": 99
      }
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/jest-runner": "^9.6.1",
    "jest": "^30.4.2",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2"
  }
}
