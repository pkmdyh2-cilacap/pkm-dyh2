{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "mutate": [
    "src/app.js",
    "src/routes/*.js",
    "!src/config/supabase.js"
  ],
  "testRunner": "jest",
  "coverageAnalysis": "perTest",
  "reporters": [
    "html",
    "clear-text",
    "progress"
  ],
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": null
  },
  "timeoutMS": 60000
}
