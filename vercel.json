{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "*.html",
          "*.css",
          "*.js",
          "*.png",
          "*.jpg",
          "*.jpeg",
          "*.svg",
          "*.ico",
          "*.webp",
          "*.gif",
          "*.json"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "server.js" }
  ]
}